---
import PageLayout from '../../../layouts/PageLayout.astro';
---

<PageLayout
  title="Contact | Académie Évolution"
  description="Questions? Reach out to Thomas directly. Replies within 24–48h."
  lang="en"
>
  <section class="relative z-20 flex min-h-[40vh] items-end border-0">
    <div class="max-w-7xl mx-auto px-6 lg:px-8 py-20 w-full">
      <span class="tag anim-fade-up" style="--delay:.2s">Contact</span>
      <h1 class="font-display text-5xl sm:text-7xl font-extrabold tracking-tighter leading-[.9] mt-4 anim-slide-l" style="--delay:.35s">Get in touch.</h1>
      <p class="text-lg text-white/65 leading-relaxed mt-6 max-w-2xl anim-fade-up" style="--delay:.5s">
        Questions about coaching, the questionnaire, or want to learn more before you start? I reply personally.
      </p>
    </div>
  </section>

  <section class="relative z-20">
    <div class="max-w-7xl mx-auto px-6 lg:px-8 py-20">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-20">
        <div>
          <div class="mt-0 space-y-5">
            <div class="glass rounded-xl p-5 flex items-center gap-4 reveal" style="--delay:.2s">
              <div class="h-10 w-10 rounded-lg glass flex items-center justify-center flex-shrink-0">
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
              </div>
              <div>
                <p class="font-display font-semibold tracking-tight">Email</p>
                <a href="mailto:info@academieevolution.com" class="text-sm text-white/55 hover:text-white transition">info@academieevolution.com</a>
              </div>
            </div>
            <div class="glass rounded-xl p-5 flex items-center gap-4 reveal" style="--delay:.3s">
              <div class="h-10 w-10 rounded-lg glass flex items-center justify-center flex-shrink-0">
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><rect width="20" height="20" x="2" y="2" rx="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/></svg>
              </div>
              <div>
                <p class="font-display font-semibold tracking-tight">Instagram</p>
                <a href="https://www.instagram.com/thomtangfitness/" target="_blank" rel="noopener noreferrer" class="text-sm text-white/55 hover:text-white transition">@thomtangfitness</a>
              </div>
            </div>
            <div class="glass rounded-xl p-5 flex items-center gap-4 reveal" style="--delay:.4s">
              <div class="h-10 w-10 rounded-lg glass flex items-center justify-center flex-shrink-0">
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><path d="M20 10c0 4.993-5.539 10.193-7.399 11.799a1 1 0 0 1-1.202 0C9.539 20.193 4 14.993 4 10a8 8 0 0 1 16 0"/><circle cx="12" cy="10" r="3"/></svg>
              </div>
              <div>
                <p class="font-display font-semibold tracking-tight">Based in</p>
                <p class="text-sm text-white/55">Quebec, Canada</p>
              </div>
            </div>
          </div>
          <div class="mt-8 reveal" style="--delay:.5s">
            <p class="text-sm text-white/60">Typical reply time: within 24–48h.</p>
          </div>
          <div class="mt-8 glass rounded-2xl p-6 reveal" style="--delay:.6s">
            <p class="font-display font-semibold tracking-tight">Ready to start coaching?</p>
            <p class="text-sm text-white/65 mt-2">The best next step is the questionnaire so I can evaluate your situation and reply with something personal.</p>
            <div class="mt-4">
              <a href="/en/signin/" class="btn btn-primary">Free consultation</a>
            </div>
          </div>
        </div>

        <div class="reveal" style="--delay:.2s">
          <p id="contact-form-status" class="text-sm text-[var(--accent)] mb-4 min-h-[1.25rem]" role="status" aria-live="polite"></p>
          <form class="glass rounded-2xl p-6 md:p-8 space-y-5" id="contact-form" novalidate>
            <input type="hidden" name="locale" value="en" />
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
              <div>
                <label for="contact-name" class="block text-sm font-display font-medium mb-2">Name</label>
                <input type="text" id="contact-name" name="name" required autocomplete="name"
                  class="w-full rounded-xl bg-white/5 border border-white/10 px-4 py-3 text-sm text-white/90 placeholder-white/35 focus:outline-none focus:ring-2 focus:ring-[var(--accent)]/50 transition"
                  placeholder="Your name" />
              </div>
              <div>
                <label for="contact-email" class="block text-sm font-display font-medium mb-2">Email</label>
                <input type="email" id="contact-email" name="email" required autocomplete="email"
                  class="w-full rounded-xl bg-white/5 border border-white/10 px-4 py-3 text-sm text-white/90 placeholder-white/35 focus:outline-none focus:ring-2 focus:ring-[var(--accent)]/50 transition"
                  placeholder="you@example.com" />
              </div>
            </div>
            <div>
              <label for="contact-subject" class="block text-sm font-display font-medium mb-2">Subject</label>
              <select id="contact-subject" name="subject" required
                class="w-full rounded-xl bg-white/5 border border-white/10 px-4 py-3 text-sm text-white/90 focus:outline-none focus:ring-2 focus:ring-[var(--accent)]/50 transition appearance-none">
                <option value="" disabled selected class="bg-neutral-900">Choose a topic</option>
                <option value="coaching" class="bg-neutral-900">Coaching question</option>
                <option value="questionnaire" class="bg-neutral-900">Question about the questionnaire</option>
                <option value="partnership" class="bg-neutral-900">Partnership / collaboration</option>
                <option value="other" class="bg-neutral-900">Other</option>
              </select>
            </div>
            <div>
              <label for="contact-message" class="block text-sm font-display font-medium mb-2">Message</label>
              <textarea id="contact-message" name="message" rows="5" required
                class="w-full rounded-xl bg-white/5 border border-white/10 px-4 py-3 text-sm text-white/90 placeholder-white/35 focus:outline-none focus:ring-2 focus:ring-[var(--accent)]/50 transition resize-none"
                placeholder="How can I help?"></textarea>
            </div>
            <button type="submit" class="btn btn-primary w-full justify-center py-3 text-base" id="contact-submit">
              Send message
              <svg class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M5 12h14M13 5l7 7-7 7"/></svg>
            </button>
          </form>
        </div>
      </div>
    </div>
  </section>
</PageLayout>

<script>
  (function () {
    const form = document.getElementById('contact-form') as HTMLFormElement | null;
    const status = document.getElementById('contact-form-status');
    const submit = document.getElementById('contact-submit') as HTMLButtonElement | null;
    if (!form || !status || !submit) return;

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      status.textContent = '';
      submit.disabled = true;
      const fd = new FormData(form);
      const body = {
        name: String(fd.get('name') ?? ''),
        email: String(fd.get('email') ?? ''),
        subject: String(fd.get('subject') ?? ''),
        message: String(fd.get('message') ?? ''),
        locale: 'en',
      };
      try {
        const res = await fetch('/api/contact/', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(body),
        });
        const data = (await res.json()) as { ok?: boolean; message?: string; error?: string };
        if (data.ok) {
          status.textContent = data.message ?? 'Thank you!';
          form.reset();
        } else {
          status.textContent = data.error ?? 'Something went wrong.';
        }
      } catch {
        status.textContent = 'Could not send right now. Email info@academieevolution.com.';
      } finally {
        submit.disabled = false;
      }
    });
  })();
</script>
