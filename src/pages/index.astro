---
import PageLayout from '../layouts/PageLayout.astro';
import Icon from '../components/Icon.astro';
import CtaSection from '../components/CtaSection.astro';
import { SITE } from '../data/site';

const localBusinessLd = {
  '@context': 'https://schema.org',
  '@type': 'LocalBusiness',
  name: SITE.name,
  description: SITE.description,
  url: SITE.url,
  areaServed: 'CA',
  address: {
    '@type': 'PostalAddress',
    addressRegion: 'QC',
    addressCountry: 'CA',
  },
};

const serviceLd = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: 'Coaching fitness pour hommes occupés',
  serviceType: 'Fitness coaching',
  provider: {
    '@type': 'LocalBusiness',
    name: SITE.name,
    url: SITE.url,
  },
  areaServed: 'CA',
};
---

<PageLayout
  title="Académie Évolution"
  description={SITE.description}
  lang="fr"
  extraJsonLd={[localBusinessLd, serviceLd]}
>
    <!-- ═══ HERO ════════════════════════════════════════ -->
    <section class="flex min-h-[90vh] z-20 relative items-end border-0">
      <div class="max-w-7xl mx-auto px-6 lg:px-8 py-20 w-full">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16 items-center">
          <h1 class="font-display text-4xl sm:text-5xl lg:text-6xl xl:text-7xl font-extrabold tracking-tighter leading-[.95] anim-slide-l" style="--delay:.3s">
            Coaching simple.<br />Résultats durables.
          </h1>

          <div class="space-y-6">
            <p class="text-lg sm:text-xl leading-relaxed text-white/75 anim-fade-up" style="--delay:.65s">
              Coaching fitness pour hommes occupés qui veulent enfin obtenir des résultats durables, sans diète extrême, sans programme irréaliste et sans vivre au gym.
            </p>

            <div class="border-t border-white/10 pt-6 anim-scale" style="--delay:.8s">
              <div class="flex flex-wrap items-center gap-4">
                <div class="relative group">
                  <a
                    href="/signin/"
                    class="btn btn-primary overflow-hidden relative shadow-[inset_0_1px_0_rgba(255,255,255,.08)]"
                    id="js-cta-primary"
                  >
                    Consultation gratuite
                    <Icon name="arrowRight" class="h-4 w-4 transition-transform duration-200 group-hover:translate-x-0.5" size={16} />
                    <span class="spotlight-glow pointer-events-none absolute inset-0 rounded-full" aria-hidden="true"></span>
                  </a>
                  <span class="pointer-events-none absolute -bottom-3 left-1/2 -translate-x-1/2 h-6 w-40 rounded-full opacity-0 group-hover:opacity-100 transition-opacity duration-300"
                        style="background: radial-gradient(60% 100% at 50% 50%, rgba(255,255,255,.5),rgba(255,255,255,.25) 35%,transparent 70%); filter: blur(10px);" aria-hidden="true"></span>
                </div>

                <span class="w-px h-6 bg-white/20" aria-hidden="true"></span>

                <a href="/programs/" class="btn bg-transparent">
                  <Icon name="play" size={15} />
                  Voir les résultats
                </a>
              </div>
            </div>

            <div class="grid grid-cols-1 sm:grid-cols-3 gap-3 anim-fade-up" style="--delay:1s">
              <div class="glass rounded-xl p-4">
                <p class="font-display font-semibold tracking-tight">Méthode simple et réaliste</p>
                <p class="text-xs text-white/55 mt-1">Pas de surcomplication. Juste ce qui marche.</p>
              </div>
              <div class="glass rounded-xl p-4">
                <p class="font-display font-semibold tracking-tight">Adaptée à ta vraie vie</p>
                <p class="text-xs text-white/55 mt-1">Job, famille, fatigue — on construit autour.</p>
              </div>
              <div class="glass rounded-xl p-4">
                <p class="font-display font-semibold tracking-tight">Résultats durables</p>
                <p class="text-xs text-white/55 mt-1">Une structure que tu peux maintenir.</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ═══ COMMENT ÇA FONCTIONNE ═════════════════════════ -->
    <section class="relative z-20">
      <div class="max-w-7xl mx-auto px-6 lg:px-8 py-24">
        <div class="text-center max-w-3xl mx-auto">
          <h2 class="font-display text-3xl sm:text-5xl font-bold tracking-tight reveal" style="--delay:.15s">Comment ça marche</h2>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-5 mt-12">
          <div class="glass rounded-2xl p-5 hover:bg-white/[.15] transition-colors reveal" style="--delay:.25s">
            <p class="text-xs text-white/60 font-display">Étape 01</p>
            <p class="font-display font-semibold tracking-tight mt-2">Tu remplis le questionnaire</p>
            <p class="body-muted mt-2">Situation, objectif et contraintes — en quelques minutes.</p>
          </div>
          <div class="glass rounded-2xl p-5 hover:bg-white/[.15] transition-colors reveal" style="--delay:.35s">
            <p class="text-xs text-white/60 font-display">Étape 02</p>
            <p class="font-display font-semibold tracking-tight mt-2">On bâtit un plan adapté</p>
            <p class="body-muted mt-2">Entraînement, alimentation et habitudes ajustés à ta réalité.</p>
          </div>
          <div class="glass rounded-2xl p-5 hover:bg-white/[.15] transition-colors reveal" style="--delay:.45s">
            <p class="text-xs text-white/60 font-display">Étape 03</p>
            <p class="font-display font-semibold tracking-tight mt-2">Tu appliques avec encadrement</p>
            <p class="body-muted mt-2">Constance et suivi — tu n'es jamais laissé seul.</p>
          </div>
          <div class="glass rounded-2xl p-5 hover:bg-white/[.15] transition-colors reveal" style="--delay:.55s">
            <p class="text-xs text-white/60 font-display">Étape 04</p>
            <p class="font-display font-semibold tracking-tight mt-2">Tu progresses durablement</p>
            <p class="body-muted mt-2">Un vrai changement, pas un sprint temporaire.</p>
          </div>
        </div>

        <div class="flex justify-center mt-8 reveal" style="--delay:.65s">
          <a href="/signin/" class="btn btn-primary">Consultation gratuite</a>
        </div>
      </div>
    </section>

    <!-- ═══ TÉMOIGNAGES / RÉSULTATS ═══════════════════════ -->
    <section class="relative z-20">
      <div class="max-w-7xl mx-auto px-6 lg:px-8 py-24">
        <div class="text-center max-w-3xl mx-auto">
          <h2 class="font-display text-3xl sm:text-5xl font-bold tracking-tight reveal" style="--delay:.15s">
            Transformations réelles.
          </h2>
        </div>

        <div class="mt-10 reveal" style="--delay:.5s">
          <div class="relative" id="carousel">
            <div class="overflow-hidden glass rounded-2xl">
              <div class="flex transition-transform duration-500 ease-out" id="carousel-track">
                <div class="w-full flex-shrink-0">
                  <div class="aspect-video flex items-center justify-center p-8 sm:p-12">
                    <div class="max-w-2xl mx-auto text-center space-y-4">
                      <blockquote class="text-lg sm:text-xl font-display font-medium leading-relaxed text-white/90">
                        "J'avais tout essayé sans jamais tenir. Avec Thomas, j'ai enfin eu une structure réaliste que je pouvais suivre malgré la job et les enfants."
                      </blockquote>
                      <div>
                        <p class="font-display font-semibold">Marc</p>
                        <p class="text-sm text-white/50">38 ans · père de deux · structure réaliste</p>
                      </div>
                    </div>
                  </div>
                </div>

                <div class="w-full flex-shrink-0">
                  <div class="aspect-video flex items-center justify-center p-8 sm:p-12">
                    <div class="max-w-2xl mx-auto text-center space-y-4">
                      <blockquote class="text-lg sm:text-xl font-display font-medium leading-relaxed text-white/90">
                        "Je voulais perdre du poids, mais surtout retrouver mon énergie. J'ai recommencé à me sentir solide et plus en contrôle."
                      </blockquote>
                      <div>
                        <p class="font-display font-semibold">Samuel</p>
                        <p class="text-sm text-white/50">42 ans · emploi exigeant · énergie retrouvée</p>
                      </div>
                    </div>
                  </div>
                </div>

                <div class="w-full flex-shrink-0">
                  <div class="aspect-video flex items-center justify-center p-8 sm:p-12">
                    <div class="max-w-2xl mx-auto text-center space-y-4">
                      <blockquote class="text-lg sm:text-xl font-display font-medium leading-relaxed text-white/90">
                        "Ce que j'ai aimé, c'est la simplicité. Pas de bullshit, pas de plan impossible. Juste ce qu'il faut pour avancer."
                      </blockquote>
                      <div>
                        <p class="font-display font-semibold">Julien</p>
                        <p class="text-sm text-white/50">35 ans · horaires variables · simplicité</p>
                      </div>
                    </div>
                  </div>
                </div>
              </div>
            </div>

            <button type="button" id="carousel-prev" class="absolute left-3 top-1/2 -translate-y-1/2 h-10 w-10 rounded-full glass flex items-center justify-center hover:bg-white/20 transition-colors z-10" aria-label="Témoignage précédent">
              <Icon name="chevronLeft" size={18} />
            </button>
            <button type="button" id="carousel-next" class="absolute right-3 top-1/2 -translate-y-1/2 h-10 w-10 rounded-full glass flex items-center justify-center hover:bg-white/20 transition-colors z-10" aria-label="Témoignage suivant">
              <Icon name="chevronRight" size={18} />
            </button>

            <div class="flex justify-center gap-2 mt-4" id="carousel-dots"></div>
          </div>
        </div>

        <div class="flex justify-center mt-6 reveal" style="--delay:.6s">
          <a href="/programs/" class="btn">Voir plus de transformations</a>
        </div>
      </div>
    </section>

    <CtaSection
      title="On commence ?"
      body="Remplis le questionnaire de départ. Ça prend quelques minutes et ça me permet de voir si ton profil correspond à ce que j'offre."
      ctaHref="/signin/"
      ctaLabel="Consultation gratuite maintenant"
      footnote="Aucune obligation. Juste une première étape claire pour voir si on est un bon fit."
    />
</PageLayout>

<script>
  (() => {
    const root = document.getElementById('carousel');
    const track = document.getElementById('carousel-track');
    const dots = document.getElementById('carousel-dots');
    const prev = document.getElementById('carousel-prev');
    const next = document.getElementById('carousel-next');
    if (!root || !track || !dots || !prev || !next) return;

    const slides = Array.from(track.children).filter((el) => el instanceof HTMLElement);
    if (slides.length <= 1) return;

    let index = 0;
    let timerId = 0;
    const prefersReducedMotion =
      window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    const dotButtons = slides.map((_, i) => {
      const btn = document.createElement('button');
      btn.type = 'button';
      btn.className =
        'h-2.5 w-2.5 rounded-full border border-white/20 transition-all hover:border-white/40 focus:outline-none focus-visible:ring-2 focus-visible:ring-[var(--accent)]';
      btn.setAttribute('aria-label', `Aller au témoignage ${i + 1}`);
      btn.addEventListener('click', () => {
        goTo(i);
        restart();
      });
      dots.appendChild(btn);
      return btn;
    });

    function render() {
      if (!track) return;
      track.style.transform = `translateX(-${index * 100}%)`;
      dotButtons.forEach((btn, i) => {
        const active = i === index;
        btn.style.background = active ? 'rgba(255,255,255,.8)' : 'rgba(255,255,255,.15)';
        btn.style.transform = active ? 'scale(1.15)' : 'scale(1)';
      });
    }

    function clamp(n: number) {
      const len = slides.length;
      return ((n % len) + len) % len;
    }

    function goTo(i: number) {
      index = clamp(i);
      render();
    }

    function start() {
      if (prefersReducedMotion) return;
      stop();
      timerId = window.setInterval(() => goTo(index + 1), 6500);
    }

    function stop() {
      if (!timerId) return;
      window.clearInterval(timerId);
      timerId = 0;
    }

    function restart() {
      stop();
      start();
    }

    prev.addEventListener('click', () => {
      goTo(index - 1);
      restart();
    });
    next.addEventListener('click', () => {
      goTo(index + 1);
      restart();
    });

    root.addEventListener('mouseenter', stop);
    root.addEventListener('mouseleave', start);
    root.addEventListener('focusin', stop);
    root.addEventListener('focusout', start);

    render();
    start();
  })();
</script>
