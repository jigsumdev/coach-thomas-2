---
import PageLayout from '../../layouts/PageLayout.astro';
---

<PageLayout
  title="Contact | Académie Évolution"
  description="Une question? Contacte Thomas directement. Réponse sous 24–48h."
  lang="fr"
>
    <section class="relative z-20 flex min-h-[40vh] items-end border-0">
      <div class="max-w-7xl mx-auto px-6 lg:px-8 py-20 w-full">
        <span class="tag anim-fade-up" style="--delay:.2s">Contact</span>
        <h1 class="font-display text-5xl sm:text-7xl font-extrabold tracking-tighter leading-[.9] mt-4 anim-slide-l" style="--delay:.35s">Écris-moi.</h1>
        <p class="text-lg text-white/65 leading-relaxed mt-6 max-w-2xl anim-fade-up" style="--delay:.5s">
          Une question sur le coaching, le questionnaire, ou juste envie d'en savoir plus avant de te lancer&nbsp;? Je te réponds personnellement.
        </p>
      </div>
    </section>

    <section class="relative z-20">
      <div class="max-w-7xl mx-auto px-6 lg:px-8 py-20">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-20">

          <div>
            <div class="mt-0 space-y-5">
              <div class="glass rounded-xl p-5 flex items-center gap-4 reveal" style="--delay:.2s">
                <div class="h-10 w-10 rounded-lg glass flex items-center justify-center flex-shrink-0">
                  <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
                </div>
                <div>
                  <p class="font-display font-semibold tracking-tight">Courriel</p>
                  <a href="mailto:info@academieevolution.com" class="text-sm text-white/55 hover:text-white transition">info@academieevolution.com</a>
                </div>
              </div>

              <div class="glass rounded-xl p-5 flex items-center gap-4 reveal" style="--delay:.3s">
                <div class="h-10 w-10 rounded-lg glass flex items-center justify-center flex-shrink-0">
                  <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect width="20" height="20" x="2" y="2" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" x2="17.51" y1="6.5" y2="6.5"/></svg>
                </div>
                <div>
                  <p class="font-display font-semibold tracking-tight">Instagram</p>
                  <a href="https://www.instagram.com/thomtangfitness/" target="_blank" rel="noopener noreferrer" class="text-sm text-white/55 hover:text-white transition">@thomtangfitness</a>
                </div>
              </div>

              <div class="glass rounded-xl p-5 flex items-center gap-4 reveal" style="--delay:.4s">
                <div class="h-10 w-10 rounded-lg glass flex items-center justify-center flex-shrink-0">
                  <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 10c0 4.993-5.539 10.193-7.399 11.799a1 1 0 0 1-1.202 0C9.539 20.193 4 14.993 4 10a8 8 0 0 1 16 0"/><circle cx="12" cy="10" r="3"/></svg>
                </div>
                <div>
                  <p class="font-display font-semibold tracking-tight">Basé au</p>
                  <p class="text-sm text-white/55">Québec, Canada</p>
                </div>
              </div>
            </div>

            <div class="mt-8 reveal" style="--delay:.5s">
              <p class="text-sm text-white/60">Délai de réponse habituel : sous 24–48 h.</p>
            </div>

            <div class="mt-8 glass rounded-2xl p-6 reveal" style="--delay:.6s">
              <p class="font-display font-semibold tracking-tight">Tu veux démarrer le coaching&nbsp;?</p>
              <p class="text-sm text-white/65 mt-2">Le meilleur moyen, c'est de remplir le questionnaire. Je pourrai évaluer ta situation et te répondre de façon personnalisée.</p>
              <div class="mt-4">
                <a href="/signin/" class="btn btn-primary">Consultation gratuite</a>
              </div>
            </div>
          </div>

          <div class="reveal" style="--delay:.2s">
            <p id="contact-form-status" class="text-sm text-[var(--accent)] mb-4 min-h-[1.25rem]" role="status" aria-live="polite"></p>
            <form class="glass rounded-2xl p-6 md:p-8 space-y-5" id="contact-form" novalidate>
              <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
                <div>
                  <label for="contact-name" class="block text-sm font-display font-medium mb-2">Nom</label>
                  <input type="text" id="contact-name" name="name" required autocomplete="name"
                    class="w-full rounded-xl bg-white/5 border border-white/10 px-4 py-3 text-sm text-white/90 placeholder-white/35 focus:outline-none focus:ring-2 focus:ring-[var(--accent)]/50 transition"
                    placeholder="Ton nom" />
                </div>
                <div>
                  <label for="contact-email" class="block text-sm font-display font-medium mb-2">Courriel</label>
                  <input type="email" id="contact-email" name="email" required autocomplete="email"
                    class="w-full rounded-xl bg-white/5 border border-white/10 px-4 py-3 text-sm text-white/90 placeholder-white/35 focus:outline-none focus:ring-2 focus:ring-[var(--accent)]/50 transition"
                    placeholder="toi@exemple.com" />
                </div>
              </div>

              <div>
                <label for="contact-subject" class="block text-sm font-display font-medium mb-2">Sujet</label>
                <select id="contact-subject" name="subject" required
                  class="w-full rounded-xl bg-white/5 border border-white/10 px-4 py-3 text-sm text-white/90 focus:outline-none focus:ring-2 focus:ring-[var(--accent)]/50 transition appearance-none">
                  <option value="" disabled selected class="bg-neutral-900">Choisis un sujet</option>
                  <option value="coaching" class="bg-neutral-900">Question sur le coaching</option>
                  <option value="questionnaire" class="bg-neutral-900">Question sur le questionnaire</option>
                  <option value="partnership" class="bg-neutral-900">Partenariat / collaboration</option>
                  <option value="other" class="bg-neutral-900">Autre</option>
                </select>
              </div>

              <div>
                <label for="contact-message" class="block text-sm font-display font-medium mb-2">Message</label>
                <textarea id="contact-message" name="message" rows="5" required
                  class="w-full rounded-xl bg-white/5 border border-white/10 px-4 py-3 text-sm text-white/90 placeholder-white/35 focus:outline-none focus:ring-2 focus:ring-[var(--accent)]/50 transition resize-none"
                  placeholder="Dis-moi comment je peux t'aider…"></textarea>
              </div>

              <button type="submit" class="btn btn-primary w-full justify-center py-3 text-base" id="contact-submit">
                Envoyer le message
                <svg class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M5 12h14M13 5l7 7-7 7"/></svg>
              </button>
            </form>
          </div>
        </div>
      </div>
    </section>
</PageLayout>

<script>
  (function () {
    const form = document.getElementById('contact-form') as HTMLFormElement | null;
    const status = document.getElementById('contact-form-status');
    const submit = document.getElementById('contact-submit') as HTMLButtonElement | null;
    if (!form || !status || !submit) return;

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      status.textContent = '';
      submit.disabled = true;
      const fd = new FormData(form);
      const body = {
        name: String(fd.get('name') ?? ''),
        email: String(fd.get('email') ?? ''),
        subject: String(fd.get('subject') ?? ''),
        message: String(fd.get('message') ?? ''),
        locale: 'fr',
      };
      try {
        const res = await fetch('/api/contact/', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(body),
        });
        const data = (await res.json()) as { ok?: boolean; message?: string; error?: string };
        if (data.ok) {
          status.textContent = data.message ?? 'Merci !';
          form.reset();
        } else {
          status.textContent = data.error ?? 'Une erreur est survenue.';
        }
      } catch {
        status.textContent = 'Impossible d’envoyer pour le moment. Écris à info@academieevolution.com.';
      } finally {
        submit.disabled = false;
      }
    });
  })();
</script>
