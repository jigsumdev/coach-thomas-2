---
import Icon from './Icon.astro';
import { getMessages, type Locale } from '../utils/i18n';

interface Props {
  lang?: Locale;
}

const { lang = 'fr' } = Astro.props;
const m = getMessages(lang);
const prefix = lang === 'fr' ? '' : '/en';

const linkClass =
  'inline-flex font-display text-[0.9375rem] font-medium tracking-tight text-white/72 hover:text-[var(--accent)] transition-colors duration-200';
const socialBtnClass =
  'inline-flex h-11 w-11 shrink-0 items-center justify-center rounded-full border border-white/10 bg-white/[0.04] text-white/55 transition duration-200 hover:border-[var(--accent)]/45 hover:bg-[var(--accent)]/[0.08] hover:text-[var(--accent)] focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-[var(--accent)]/60';
const colHeadingClass =
  'mb-5 font-display text-[11px] font-semibold uppercase tracking-[0.2em] text-white/38';
---

<footer class="site-footer relative z-20 overflow-hidden border-t border-white/[0.08]">
  <div
    class="pointer-events-none absolute inset-x-0 top-0 h-px bg-gradient-to-r from-transparent via-[var(--accent)]/35 to-transparent"
    aria-hidden="true"
  />

  <div class="relative mx-auto max-w-7xl px-6 py-14 lg:px-8 lg:py-16">
    <!-- Primary link columns -->
    <div class="grid grid-cols-1 gap-12 sm:grid-cols-2 sm:gap-x-16 lg:gap-x-24">
      <nav aria-label={m.footer.menu} role="navigation">
        <p class={colHeadingClass}>{m.footer.menu}</p>
        <ul class="flex flex-col gap-3.5">
          <li><a href={`${prefix}/`} class={linkClass}>{m.nav.home}</a></li>
          <li><a href={`${prefix}/coaches/`} class={linkClass}>{m.nav.coaching}</a></li>
          <li><a href={`${prefix}/programs/`} class={linkClass}>{m.nav.results}</a></li>
          <li><a href={`${prefix}/about/`} class={linkClass}>{m.nav.about}</a></li>
          <li><a href={`${prefix}/support/`} class={linkClass}>{m.nav.faq}</a></li>
        </ul>
      </nav>

      <nav aria-label={m.footer.legal} role="navigation">
        <p class={colHeadingClass}>{m.footer.legal}</p>
        <ul class="flex flex-col gap-3.5">
          <li><a href={`${prefix}/terms/`} class={linkClass}>{m.footer.terms}</a></li>
          <li><a href={`${prefix}/privacy/`} class={linkClass}>{m.footer.privacy}</a></li>
          <li><a href={`${prefix}/cookies/`} class={linkClass}>{m.footer.cookies}</a></li>
        </ul>
      </nav>
    </div>

    <!-- Brand strip -->
    <div
      class="mt-14 flex flex-col gap-8 border-t border-white/[0.08] pt-14 md:flex-row md:items-center md:justify-between md:gap-12"
    >
      <div class="min-w-0 max-w-lg">
        <a
          href={`${prefix}/`}
          class="font-display text-xl font-bold tracking-tight text-white sm:text-2xl"
          aria-label="Académie Évolution"
        >
          Académie <span class="text-white/60">Évolution</span>
        </a>
        <p class="mt-3 text-sm leading-relaxed text-white/48">{m.footer.tagline}</p>
      </div>

      <div class="flex shrink-0 flex-wrap items-center gap-3 sm:gap-3.5 md:justify-end">
        <a
          href="https://www.instagram.com/thomtangfitness/"
          target="_blank"
          rel="noopener noreferrer"
          class={socialBtnClass}
          aria-label="Instagram"
        >
          <Icon name="instagram" size={22} />
        </a>
        <a
          href="https://www.tiktok.com/@thomtangfitness"
          target="_blank"
          rel="noopener noreferrer"
          class={socialBtnClass}
          aria-label="TikTok"
        >
          <Icon name="tiktok" size={22} />
        </a>
        <a
          href="https://www.facebook.com/coach.thom.tang/"
          target="_blank"
          rel="noopener noreferrer"
          class={socialBtnClass}
          aria-label="Facebook"
        >
          <Icon name="facebook" size={22} />
        </a>
      </div>
    </div>

    <!-- Copyright -->
    <div class="mt-12 border-t border-white/[0.08] pt-8 text-center">
      <p class="text-xs leading-relaxed text-white/38">
        &copy; 2026 Académie Évolution. {m.footer.copyright}
      </p>
    </div>
  </div>
</footer>
