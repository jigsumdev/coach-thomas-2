---
type IconName =
  | 'check'
  | 'arrowRight'
  | 'play'
  | 'chevronLeft'
  | 'chevronRight'
  | 'plus'
  | 'mail'
  | 'instagram'
  | 'tiktok'
  | 'facebook'
  | 'mapPin'
  | 'menu'
  | 'close';

interface Props {
  name: IconName;
  class?: string;
  size?: number;
  id?: string;
}

const { name, class: className = '', size = 16, id } = Astro.props;
const s = size;
---

{name === 'check' && (
  <svg xmlns="http://www.w3.org/2000/svg" width={s} height={s} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class={className} aria-hidden="true"><path d="M20 6 9 17l-5-5"/></svg>
)}
{name === 'arrowRight' && (
  <svg class={className} fill="none" stroke="currentColor" stroke-width="2" width={s} height={s} viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M5 12h14M13 5l7 7-7 7"/></svg>
)}
{name === 'play' && (
  <svg xmlns="http://www.w3.org/2000/svg" width={s} height={s} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class={className} aria-hidden="true"><path d="M5 5a2 2 0 0 1 3.008-1.728l11.997 6.998a2 2 0 0 1 .003 3.458l-12 7A2 2 0 0 1 5 19z"/></svg>
)}
{name === 'chevronLeft' && (
  <svg xmlns="http://www.w3.org/2000/svg" width={s} height={s} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class={className} aria-hidden="true"><path d="m15 18-6-6 6-6"/></svg>
)}
{name === 'chevronRight' && (
  <svg xmlns="http://www.w3.org/2000/svg" width={s} height={s} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class={className} aria-hidden="true"><path d="m9 18 6-6-6-6"/></svg>
)}
{name === 'plus' && (
  <svg xmlns="http://www.w3.org/2000/svg" width={s} height={s} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class={className} aria-hidden="true"><path d="M5 12h14"/><path d="M12 5v14"/></svg>
)}
{name === 'mail' && (
  <svg xmlns="http://www.w3.org/2000/svg" width={s} height={s} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class={className} aria-hidden="true"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
)}
{name === 'instagram' && (
  <svg xmlns="http://www.w3.org/2000/svg" width={s} height={s} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class={className} aria-hidden="true"><rect width="20" height="20" x="2" y="2" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" x2="17.51" y1="6.5" y2="6.5"/></svg>
)}
{name === 'tiktok' && (
  <svg xmlns="http://www.w3.org/2000/svg" width={s} height={s} viewBox="0 0 24 24" class={className} aria-hidden="true"><path fill="currentColor" d="M19.589 6.686a4.793 4.793 0 0 1-3.77-4.25V2h-3.992v13.672c0 1.82-1.516 3.307-3.38 3.307c-1.863 0-3.379-1.487-3.379-3.307c0-1.82 1.516-3.307 3.38-3.307c.356 0 .701.054 1.025.155V8.418a7.45 7.45 0 0 0-1.025-.07C4.34 8.348 1 11.62 1 15.672S4.34 23 8.448 23c4.107 0 7.447-3.276 7.447-7.328V9.84a8.793 8.793 0 0 0 3.694.81V6.785c-.001 0 .001-.07 0-.099Z"/></svg>
)}
{name === 'facebook' && (
  <svg xmlns="http://www.w3.org/2000/svg" width={s} height={s} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class={className} aria-hidden="true"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/></svg>
)}
{name === 'mapPin' && (
  <svg xmlns="http://www.w3.org/2000/svg" width={s} height={s} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class={className} aria-hidden="true"><path d="M20 10c0 4.993-5.539 10.193-7.399 11.799a1 1 0 0 1-1.202 0C9.539 20.193 4 14.993 4 10a8 8 0 0 1 16 0"/><circle cx="12" cy="10" r="3"/></svg>
)}
{name === 'menu' && (
  <svg xmlns="http://www.w3.org/2000/svg" id={id} width={s} height={s} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class={className} aria-hidden="true"><path d="M4 5h16M4 12h16M4 19h16"/></svg>
)}
{name === 'close' && (
  <svg xmlns="http://www.w3.org/2000/svg" id={id} width={s} height={s} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class={className} aria-hidden="true"><path d="m18 6-12 12M6 6l12 12"/></svg>
)}
